# Application
APP_NAME="Daggerheart Fichas API"
APP_ENV=development
API_VERSION=0.4.11

# PostgreSQL async SQLAlchemy URL
DATABASE_URL=postgresql+asyncpg://daggerheart:daggerheart@localhost:5432/daggerheart_fichas

# Host header and browser-origin allowlists. Production must list the public API host.
TRUSTED_HOSTS=localhost,127.0.0.1,testserver
CORS_ALLOWED_ORIGINS='["http://localhost:5173","http://127.0.0.1:5173"]'
# Explicit preflight headers; X-Request-ID and X-CSRF-Token are added automatically.
CORS_ALLOWED_HEADERS=Accept,Accept-Language,Cache-Control,Content-Language,Content-Type,Last-Event-ID,Pragma
CORS_MAX_AGE_SECONDS=600
API_DOCS_ENABLED=true

# Request correlation and stable error contract
REQUEST_ID_HEADER_NAME=X-Request-ID
REQUEST_ID_MAX_LENGTH=96
ACCEPT_INCOMING_REQUEST_ID=true
REQUEST_VALIDATION_MAX_ERRORS=20

# Structured logs and Prometheus metrics
STRUCTURED_LOGGING_ENABLED=true
LOG_LEVEL=INFO
LOG_MAX_FIELD_LENGTH=512
# Keep false in production unless the log destination is explicitly reviewed.
LOG_INCLUDE_EXCEPTION_TRACEBACKS=false
LOG_SUCCESSFUL_HTTP_REQUESTS=true
DISABLE_UVICORN_ACCESS_LOG=true
METRICS_ENABLED=false
# Required when METRICS_ENABLED=true in production; send as Authorization: Bearer.
METRICS_BEARER_TOKEN=

# Auth/session settings. Use a long random value outside development.
SESSION_SECRET=change-me-before-production
SESSION_COOKIE_NAME=daggerheart_refresh_token
SESSION_COOKIE_SECURE=false
# Production must use true; when unset the default is false locally and true in production.
COOKIE_HOST_PREFIX=false
COOKIE_SAMESITE=lax
COOKIE_PATH=/
COOKIE_DOMAIN=
SESSION_DURATION_DAYS=30

# Global browser response headers. Production requires these and HSTS.
SECURITY_HEADERS_ENABLED=true
CONTENT_SECURITY_POLICY="default-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'none'"
REFERRER_POLICY=no-referrer
PERMISSIONS_POLICY="accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
HSTS_ENABLED=false
HSTS_MAX_AGE_SECONDS=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=false

# Global and feature payload contracts
MAX_REQUEST_BODY_BYTES=6291456
MAX_CLOUD_BACKUP_PAYLOAD_BYTES=5242880
MAX_CLOUD_CHARACTER_PAYLOAD_BYTES=2097152
MAX_CHARACTER_MUTATION_PAYLOAD_BYTES=262144
MAX_CHARACTER_MUTATION_OPERATIONS=128
MAX_CHARACTER_MUTATION_CHANGED_PATHS=128
MAX_CHARACTER_MUTATION_PATH_LENGTH=512
MAX_CHARACTER_MUTATION_PATH_SEGMENTS=32
MAX_DEVICE_ID_LENGTH=128
MAX_SHARE_TARGET_LENGTH=320
MAX_JSON_DEPTH=32
# UTF-8 bytes, applied to JSON keys and string values
MAX_JSON_STRING_LENGTH=262144

# Cloud backup and character schema contracts
CLOUD_BACKUP_RETENTION_LIMIT=10
SUPPORTED_CLOUD_BACKUP_FORMAT_VERSION=1
SUPPORTED_LOCAL_BACKUP_FORMAT_VERSION=1
SUPPORTED_CLOUD_CHARACTER_SCHEMA_VERSION=1

# Character realtime events
CHARACTER_EVENT_RETENTION_DAYS=30
CHARACTER_EVENT_RETENTION_REVISIONS=500
# Path-only compacted history used by owner mutation merge checks.
CHARACTER_EVENT_COMPACTION_RETENTION_DAYS=90
CHARACTER_EVENT_COMPACTION_RETENTION_REVISIONS=2000
CHARACTER_EVENT_REPLAY_BATCH_SIZE=100
CHARACTER_EVENT_POLL_INTERVAL_SECONDS=1
CHARACTER_EVENT_HEARTBEAT_SECONDS=15
CHARACTER_EVENT_ACCESS_RECHECK_SECONDS=5
# Bound database and downstream proxy stalls. Both close the stream so EventSource reconnects.
CHARACTER_EVENT_QUERY_TIMEOUT_SECONDS=5
CHARACTER_EVENT_SEND_TIMEOUT_SECONDS=10
# Rotate long-lived streams to make deploys/load-balancing deterministic.
CHARACTER_EVENT_STREAM_MAX_DURATION_SECONDS=300
CHARACTER_EVENT_STREAM_ROTATION_JITTER_SECONDS=30
CHARACTER_EVENT_SHUTDOWN_GRACE_SECONDS=15
# Native EventSource reconnection delay sent in the SSE retry field.
CHARACTER_EVENT_RETRY_MILLISECONDS=3000

# CSRF protection. Keep enabled outside isolated backend-only tests.
CSRF_ENABLED=true
CSRF_COOKIE_NAME=daggerheart_csrf_token
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_TOKEN_BYTES=32
# Empty means: use CORS_ALLOWED_ORIGINS.
CSRF_TRUSTED_ORIGINS=

# Rate limiting. Development/test may omit Redis and use the process-local store.
RATE_LIMIT_ENABLED=false
# Required in staging/production when RATE_LIMIT_ENABLED=true.
RATE_LIMIT_STORAGE_URL=
RATE_LIMIT_KEY_PREFIX=daggerheart
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_SSE_LEASE_SECONDS=90
# true keeps the API available during a limiter-store outage; false returns 503.
RATE_LIMIT_FAIL_OPEN=true
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_SHARE_PER_MINUTE=20
RATE_LIMIT_MUTATION_PER_MINUTE=120
RATE_LIMIT_READ_PER_MINUTE=300
RATE_LIMIT_SSE_CONNECTIONS_PER_USER=10
RATE_LIMIT_SSE_CONNECTIONS_PER_CHARACTER=5

# Bounded retries for idempotent owner mutations after PostgreSQL concurrency errors.
CHARACTER_WRITE_RETRY_ATTEMPTS=3
CHARACTER_WRITE_RETRY_BASE_DELAY_MS=25
CHARACTER_WRITE_RETRY_MAX_DELAY_MS=250

# Audit contract.
AUDIT_ENABLED=false
AUDIT_RETENTION_DAYS=90
AUDIT_IP_MODE=none
# Required only when AUDIT_ENABLED=true and AUDIT_IP_MODE=hash.
AUDIT_HASH_SECRET=
AUDIT_USER_AGENT_MAX_LENGTH=256

# Privacy and inactive-data lifecycle. Active characters/shares and manual backups are excluded.
CLOUD_CHARACTER_TOMBSTONE_RETENTION_DAYS=30
PENDING_SHARE_RETENTION_DAYS=30
REVOKED_SHARE_RETENTION_DAYS=30
REFRESH_SESSION_RETENTION_DAYS=7
DATA_LIFECYCLE_BATCH_SIZE=500

# Controlled rollout and emergency rollback switches. Reads remain available.
CLOUD_SNAPSHOT_WRITES_ENABLED=true
CLOUD_MUTATIONS_ENABLED=true
CHARACTER_SHARING_WRITES_ENABLED=true
CHARACTER_SSE_ENABLED=true
ROLLOUT_RETRY_AFTER_SECONDS=60
# Build, image digest or Git SHA surfaced by readiness checks and structured logs.
RELEASE_REVISION=
