# Backend
APP_NAME="Daggerheart Fichas API"
APP_ENV=development
API_VERSION=0.2.0

# PostgreSQL async SQLAlchemy URL
DATABASE_URL=postgresql+asyncpg://daggerheart:daggerheart@localhost:5432/daggerheart_fichas

# Frontend origins allowed for browser requests with credentials.
# Use comma-separated values in production, e.g. https://app.example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Auth placeholder for the next step. Replace before implementing sessions.
SESSION_SECRET=change-me-before-production

# Auth/session settings. Use a long random value in staging/production.
SESSION_COOKIE_NAME=daggerheart_refresh_token
SESSION_COOKIE_SECURE=false
SESSION_DURATION_DAYS=30
# Cloud backups
MAX_CLOUD_BACKUP_PAYLOAD_BYTES=5242880
CLOUD_BACKUP_RETENTION_LIMIT=10
SUPPORTED_CLOUD_BACKUP_FORMAT_VERSION=1
SUPPORTED_LOCAL_BACKUP_FORMAT_VERSION=1
